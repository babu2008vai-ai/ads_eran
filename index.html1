    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        /* ===== Global Reset ===== */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #0f0f1a; color: #ffffff; overflow-x: hidden; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #1a1a2e; }
        ::-webkit-scrollbar-thumb { background: #e94560; border-radius: 10px; }

        /* ===== Navbar ===== */
        .navbar { position: fixed; top: 0; width: 100%; background: rgba(15, 15, 26, 0.95); backdrop-filter: blur(10px); z-index: 1000; padding: 10px 0; border-bottom: 1px solid #e9456033; }
        .nav-container { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 0 20px; }
        .logo { display: flex; align-items: center; gap: 10px; font-size: 1.5rem; font-weight: bold; color: #e94560; }
        .logo i { font-size: 1.8rem; animation: spin 3s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        .nav-links { display: flex; gap: 25px; }
        .nav-links a { color: #ccc; text-decoration: none; font-size: 0.95rem; transition: color 0.3s; }
        .nav-links a:hover { color: #e94560; }
        .nav-buttons { display: flex; gap: 10px; }
        .btn-login { padding: 8px 20px; background: transparent; border: 2px solid #e94560; color: #e94560; border-radius: 25px; cursor: pointer; font-size: 0.9rem; transition: all 0.3s; }
        .btn-login:hover { background: #e94560; color: white; }
        .btn-signup { padding: 8px 20px; background: linear-gradient(135deg, #e94560, #c23152); border: none; color: white; border-radius: 25px; cursor: pointer; font-size: 0.9rem; transition: all 0.3s; }
        .btn-signup:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(233, 69, 96, 0.4); }
        .user-panel { display: flex; align-items: center; gap: 15px; }
        .user-name { color: #e94560; font-weight: bold; }
        .user-balance { background: linear-gradient(135deg, #00b894, #00a381); padding: 5px 15px; border-radius: 20px; font-weight: bold; font-size: 0.9rem; }
        .btn-logout { padding: 5px 15px; background: #333; border: none; color: #ccc; border-radius: 15px; cursor: pointer; font-size: 0.8rem; }
        .hamburger { display: none; font-size: 1.5rem; cursor: pointer; color: #e94560; }

        /* ===== Hero Section ===== */
        .hero { min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 100px 20px; background: radial-gradient(ellipse at center, #1a1a3e 0%, #0f0f1a 70%); }
        .hero-content { max-width: 800px; }
        .hero h1 { font-size: 2.8rem; margin-bottom: 20px; background: linear-gradient(135deg, #e94560, #f5a623); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .hero p { font-size: 1.2rem; color: #aaa; margin-bottom: 40px; }
        .hero-stats { display: flex; justify-content: center; gap: 40px; margin-bottom: 40px; }
        .stat { text-align: center; }
        .stat h3 { font-size: 2rem; color: #f5a623; }
        .stat p { color: #888; font-size: 0.9rem; }
        .btn-hero { padding: 15px 40px; font-size: 1.2rem; background: linear-gradient(135deg, #e94560, #c23152); border: none; color: white; border-radius: 50px; cursor: pointer; transition: all 0.3s; animation: pulse 2s infinite; }
        @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(233, 69, 96, 0.7); } 70% { box-shadow: 0 0 0 20px rgba(233, 69, 96, 0); } 100% { box-shadow: 0 0 0 0 rgba(233, 69, 96, 0); } }
        .btn-hero:hover { transform: translateY(-3px); }

        /* ===== Sections ===== */
        .section-title { text-align: center; font-size: 2rem; margin-bottom: 40px; color: #f5a623; }
        .how-it-works { padding: 80px 20px; background: #12121f; }
        .steps-container { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 30px; }
        .step { background: linear-gradient(135deg, #1a1a2e, #16213e); padding: 30px; border-radius: 15px; text-align: center; border: 1px solid #e9456022; transition: all 0.3s; }
        .step:hover { transform: translateY(-10px); border-color: #e94560; box-shadow: 0 10px 30px rgba(233, 69, 96, 0.2); }
        .step-icon { font-size: 2.5rem; margin-bottom: 15px; }
        .step h3 { margin-bottom: 10px; color: #e94560; }
        .step p { color: #888; font-size: 0.9rem; }

        /* ===== Ad Banner Container ===== */
        .ad-banner-container { max-width: 728px; margin: 20px auto; text-align: center; padding: 10px; background: #1a1a2e; border-radius: 10px; border: 1px dashed #e9456033; min-height: 90px; display: flex; align-items: center; justify-content: center; }
        .ad-banner-container .ad-label { color: #555; font-size: 0.75rem; display: block; margin-bottom: 5px; }

        /* ===== Dashboard ===== */
        .dashboard { padding: 80px 20px; max-width: 1200px; margin: 0 auto; }
        .ad-stats { display: flex; justify-content: center; gap: 30px; margin-bottom: 40px; flex-wrap: wrap; }
        .ad-stat-card { background: linear-gradient(135deg, #1a1a2e, #16213e); padding: 25px 40px; border-radius: 15px; text-align: center; border: 1px solid #e9456033; min-width: 180px; }
        .ad-stat-card i { font-size: 2rem; color: #e94560; margin-bottom: 10px; }
        .ad-stat-card h3 { font-size: 1.8rem; color: #f5a623; }
        .ad-stat-card p { color: #888; font-size: 0.85rem; }

        .ad-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
        .ad-card { background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 15px; overflow: hidden; border: 1px solid #e9456022; transition: all 0.3s; }
        .ad-card:hover { transform: translateY(-5px); border-color: #e94560; box-shadow: 0 10px 25px rgba(233, 69, 96, 0.2); }
        .ad-card-header { padding: 20px; background: linear-gradient(135deg, #e9456022, #f5a62322); text-align: center; }
        .ad-card-header .ad-icon { font-size: 2.5rem; margin-bottom: 10px; }
        .ad-card-body { padding: 20px; }
        .ad-card-body h3 { margin-bottom: 8px; color: #fff; }
        .ad-card-body .ad-duration { color: #888; font-size: 0.9rem; margin-bottom: 5px; }
        .ad-card-body .ad-reward { color: #00b894; font-size: 1.1rem; font-weight: bold; margin-bottom: 15px; }

        .btn-watch { width: 100%; padding: 12px; background: linear-gradient(135deg, #e94560, #c23152); border: none; color: white; border-radius: 10px; cursor: pointer; font-size: 1rem; transition: all 0.3s; }
        .btn-watch:hover { opacity: 0.9; transform: translateY(-2px); }
        .login-required { text-align: center; padding: 60px 20px; display: none; }
        .login-required i { font-size: 3rem; color: #e94560; margin-bottom: 20px; }
        .login-required h3 { margin-bottom: 10px; color: #ccc; }
        .login-required p { color: #888; margin-bottom: 20px; }

        /* ===== Watch Modal ===== */
        .ad-watch-content { max-width: 600px; text-align: center; }
        .ad-watch-header { margin-bottom: 20px; }
        .ad-watch-header h2 { color: #e94560; margin-bottom: 20px; }
        .timer-circle { width: 100px; height: 100px; border-radius: 50%; border: 4px solid #e94560; display: flex; align-items: center; justify-content: center; margin: 0 auto 10px; font-size: 2rem; font-weight: bold; color: #f5a623; position: relative; }
        .timer-circle::after { content: ''; position: absolute; width: 100%; height: 100%; border-radius: 50%; border: 4px solid transparent; border-top-color: #f5a623; animation: countdown 1s linear infinite; }
        @keyframes countdown { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        .ad-display { margin: 20px 0; }
        .progress-bar { width: 100%; height: 6px; background: #333; border-radius: 10px; margin: 15px 0; overflow: hidden; }
        .progress { height: 100%; background: linear-gradient(90deg, #e94560, #f5a623); width: 0%; border-radius: 10px; transition: width 1s linear; }
        .ad-instruction { color: #888; margin-bottom: 15px; }
        .btn-claim { padding: 12px 40px; background: linear-gradient(135deg, #00b894, #00a381); border: none; color: white; border-radius: 25px; cursor: pointer; font-size: 1.1rem; transition: all 0.3s; }
        .btn-claim:disabled { background: #333; cursor: not-allowed; }

        /* ===== Withdraw & Referral ===== */
        .withdraw-section { padding: 80px 20px; background: #12121f; }
        .withdraw-container { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
        .withdraw-info { display: flex; flex-direction: column; gap: 20px; }
        .withdraw-card { background: linear-gradient(135deg, #1a1a2e, #16213e); padding: 25px; border-radius: 15px; border: 1px solid #e9456022; }
        .withdraw-card h3 { color: #e94560; margin-bottom: 8px; }
        .withdraw-card p { color: #888; font-size: 0.9rem; }
        .withdraw-form { background: linear-gradient(135deg, #1a1a2e, #16213e); padding: 30px; border-radius: 15px; border: 1px solid #e9456022; }
        .withdraw-form h3 { color: #f5a623; margin-bottom: 20px; text-align: center; }
        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; margin-bottom: 6px; color: #ccc; font-size: 0.9rem; }
        .form-group input, .form-group select { width: 100%; padding: 12px 15px; background: #0f0f1a; border: 1px solid #333; border-radius: 10px; color: white; font-size: 1rem; }
        .form-group input:focus, .form-group select:focus { outline: none; border-color: #e94560; }
        .btn-withdraw, .btn-submit { width: 100%; padding: 12px; background: linear-gradient(135deg, #e94560, #c23152); border: none; color: white; border-radius: 10px; cursor: pointer; font-size: 1rem; font-weight: bold; transition: all 0.3s; }
        .btn-withdraw:hover, .btn-submit:hover { transform: translateY(-2px); }

        .referral-section { padding: 80px 20px; text-align: center; max-width: 800px; margin: 0 auto; }
        .referral-bonus { background: linear-gradient(135deg, #f5a623, #e8961e); padding: 25px; border-radius: 15px; margin-bottom: 25px; color: #000; }
        .referral-link-box { display: flex; gap: 10px; max-width: 500px; margin: 0 auto; }
        .referral-link-box input { flex: 1; padding: 12px; background: #1a1a2e; border: 1px solid #333; border-radius: 10px; color: #ccc; }
        .referral-link-box button { padding: 12px 20px; background: #e94560; border: none; color: white; border-radius: 10px; cursor: pointer; }

        /* ===== Leaderboard ===== */
        .leaderboard-section { padding: 80px 20px; background: #12121f; }
        .leaderboard-container { max-width: 600px; margin: 0 auto; }
        .leaderboard-item { display: flex; align-items: center; gap: 15px; padding: 15px 20px; background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 12px; margin-bottom: 10px; border: 1px solid #e9456022; }
        .leaderboard-rank { font-size: 1.5rem; font-weight: bold; min-width: 40px; text-align: center; }
        .leaderboard-rank.gold { color: #FFD700; }
        .leaderboard-rank.silver { color: #C0C0C0; }
        .leaderboard-rank.bronze { color: #CD7F32; }
        .leaderboard-info { flex: 1; }
        .leaderboard-info h4 { color: #fff; }
        .leaderboard-info p { color: #888; font-size: 0.85rem; }
        .leaderboard-amount { color: #00b894; font-weight: bold; }

        /* ===== Modals & Toast ===== */
        .modal { display: none; position: fixed; z-index: 2000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.8); backdrop-filter: blur(5px); }
        .modal-content { background: #1a1a2e; margin: 5% auto; padding: 30px; border-radius: 20px; width: 90%; max-width: 450px; border: 1px solid #e9456033; position: relative; }
        .close-modal { position: absolute; top: 15px; right: 20px; font-size: 1.8rem; color: #888; cursor: pointer; }
        .close-modal:hover { color: #e94560; }
        .modal-content h2 { text-align: center; color: #e94560; margin-bottom: 25px; }
        .form-group input { width: 100%; padding: 12px; margin-top: 5px; }
        .toast { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(100px); background: linear-gradient(135deg, #1a1a2e, #16213e); color: white; padding: 15px 30px; border-radius: 10px; border: 1px solid #e94560; z-index: 3000; transition: transform 0.4s; }
        .toast.show { transform: translateX(-50%) translateY(0); }
        .notification-bell { position: fixed; bottom: 20px; right: 20px; width: 60px; height: 60px; background: linear-gradient(135deg, #e94560, #c23152); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; cursor: pointer; z-index: 999; box-shadow: 0 5px 20px rgba(233, 69, 96, 0.5); }

        .footer { background: #0a0a15; padding: 40px 20px 20px; border-top: 1px solid #e9456022; text-align: center; color: #555; font-size: 0.85rem; }

        @media (max-width: 768px) {
            .nav-links { display: none; position: absolute; top: 60px; left: 0; width: 100%; background: #1a1a2e; flex-direction: column; padding: 20px; gap: 15px; border-bottom: 2px solid #e94560; }
            .nav-links.active { display: flex; }
            .nav-buttons, .user-panel { display: none !important; }
            .hamburger { display: block; }
            .hero h1 { font-size: 1.8rem; }
            .hero-stats { flex-direction: column; gap: 15px; }
            .withdraw-container { grid-template-columns: 1fr; }
            .referral-link-box { flex-direction: column; }
            .ad-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <div class="notification-bell" onclick="showModal('dailyBonusModal')">🎁</div>

    <nav class="navbar">
        <div class="nav-container">
            <div class="logo"><i class="fas fa-coins"></i> <span>AdWatch BD</span></div>
            <div class="nav-links" id="navLinks">
                <a href="#home">হোম</a>
                <a href="#how-it-works">কিভাবে কাজ করে</a>
                <a href="#earnings">আজকের কাজ</a>
                <a href="#leaderboard">লিডারবোর্ড</a>
                <a href="#withdraw">টাকা উত্তোলন</a>
            </div>
            <div class="nav-buttons" id="navButtons">
                <button class="btn-login" onclick="showModal('loginModal')">لগইন</button>
                <button class="btn-signup" onclick="showModal('signupModal')">সাইন আপ</button>
            </div>
            <div class="user-panel" id="userPanel" style="display:none;">
                <span class="user-name" id="displayName"></span>
                <span class="user-balance">💰 ৳<span id="displayBalance">0</span></span>
                <button class="btn-logout" onclick="logout()">লগআউট</button>
            </div>
            <div class="hamburger" onclick="toggleMenu()"><i class="fas fa-bars"></i></div>
        </div>
    </nav>

    <section class="hero" id="home">
        <div class="hero-content">
            <h1>📺 Ad দেখুন, টাকা আয় করুন!</h1>
            <p>প্রতিদিন মাত্র কয়েক মিনিট কাজ করে নির্ভরযোগ্য আয় নিশ্চিত করুন।</p>
            <div class="hero-stats">
                <div class="stat"><h3>১০,০০০+</h3><p>সক্রিয় ইউজার</p></div>
                <div class="stat"><h3>৳৫ লাখ+</h3><p>মোট পেমেন্ট</p></div>
                <div class="stat"><h3>৫০০+</h3><p>দৈনিক Ad</p></div>
            </div>
            <button class="btn-hero" onclick="showModal('signupModal')">🚀 এখনই শুরু করুন - ফ্রি!</button>
        </div>
    </section>

    <!-- Top Banner -->
    <div class="ad-banner-container">
        <div>
            <span class="ad-label">📢 বিজ্ঞাপন</span>
            <div id="ad-banner-top">
                <script type="text/javascript">
                  atOptions = { 'key' : 'd204cdd511360aa9f71e123718ee1bcb', 'format' : 'iframe', 'height' : 60, 'width' : 468, 'params' : {} };
                </script>
                <script type="text/javascript" src="https://www.highperformanceformat.com/d204cdd511360aa9f71e123718ee1bcb/invoke.js"></script>
            </div>
        </div>
    </div>

    <section class="how-it-works" id="how-it-works">
        <h2 class="section-title">📋 কিভাবে কাজ করে?</h2>
        <div class="steps-container">
            <div class="step"><div>1️⃣</div><h3>রেজিস্ট্রেশন</h3><p>ফ্রি অ্যাকাউন্ট তৈরি করুন</p></div>
            <div class="step"><div>2️⃣</div><h3>Ad দেখুন</h3><p>টাস্ক কমপ্লিট করুন</p></div>
            <div class="step"><div>3️⃣</div><h3>আয় করুন</h3><p>ওয়ালেটে টাকা জমা হবে</p></div>
            <div class="step"><div>4️⃣</div><h3>টাকা তুলুন</h3><p>বিকাশ বা নগদে পেমেন্ট</p></div>
        </div>
    </section>

    <section class="dashboard" id="earnings">
        <h2 class="section-title">💰 আজকের উপলব্ধ Ad সমূহ</h2>
        <div class="ad-stats">
            <div class="ad-stat-card"><i class="fas fa-eye"></i><h3 id="todayWatched">0</h3><p>আজ দেখা হয়েছে</p></div>
            <div class="ad-stat-card"><i class="fas fa-clock"></i><h3 id="todayRemaining">10</h3><p>বাকি আছে</p></div>
            <div class="ad-stat-card"><i class="fas fa-money-bill-wave"></i><h3>৳<span id="todayEarned">0</span></h3><p>আজকের আয়</p></div>
        </div>
        <div class="ad-grid" id="adGrid"></div>
        <div class="login-required" id="loginRequired">
            <i class="fas fa-lock"></i><h3>কাজ করতে লগইন করুন</h3>
            <button class="btn-signup" onclick="showModal('signupModal')">সাইন আপ করুন</button>
        </div>
    </section>

    <!-- Ad Watching Modal -->
    <div class="modal ad-modal" id="adWatchModal">
        <div class="modal-content ad-watch-content">
            <div class="ad-watch-header">
                <h2>📺 Ad দেখছেন...</h2>
                <div class="timer-circle"><span id="timerText">30</span></div>
            </div>
            <div class="progress-bar"><div class="progress" id="adProgress"></div></div>
            <p class="ad-instruction">⏳ সম্পূর্ণ Ad দেখুন, সময় শেষে টাকা নিন।</p>
            <button class="btn-claim" id="btnClaim" onclick="claimReward()" disabled>✅ টাকা নিন</button>
        </div>
    </div>

    <section class="withdraw-section" id="withdraw">
        <h2 class="section-title">💳 টাকা তুলুন</h2>
        <div class="withdraw-container">
            <div class="withdraw-info">
                <div class="withdraw-card"><h3>📱 bKash / Nagad</h3><p>সর্বনিম্ন উত্তোলন: ৳৫০</p><p>পেমেন্ট সময়কাল: ২৪ ঘণ্টা</p></div>
            </div>
            <div class="withdraw-form">
                <h3>উত্তোলন ফরম</h3>
                <div class="form-group"><label>মেথড:</label><select id="withdrawMethod"><option value="bkash">bKash</option><option value="nagad">Nagad</option></select></div>
                <div class="form-group"><label>নম্বর:</label><input type="text" id="withdrawNumber" placeholder="01XXXXXXXXX"></div>
                <div class="form-group"><label>পরিমাণ (৳):</label><input type="number" id="withdrawAmount" placeholder="৫০"></div>
                <button class="btn-withdraw" onclick="requestWithdraw()">💸 আবেদন করুন</button>
            </div>
        </div>
    </section>

    <section class="referral-section">
        <h2 class="section-title">👥 রেফারেল বোনাস সিস্টেম</h2>
        <div class="referral-content">
            <div class="referral-bonus"><h3>🎉 প্রতি সফল রেফারে পাবেন ৳১০ ইনস্ট্যান্ট বোনাস!</h3></div>
            <div class="referral-link-box">
                <input type="text" id="referralLink" readonly value="লগইন করুন প্রথমে">
                <button onclick="copyReferral()">📋 কপি করুন</button>
            </div>
        </div>
    </section>

    <footer class="footer"><p>© ২০২৬ AdWatch BD - সর্বস্বত্ব সংরক্ষিত।</p></footer>

    <!-- Signup Modal -->
    <div class="modal" id="signupModal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeModal('signupModal')">&times;</span>
            <h2>📝 সাইন আপ করুন</h2>
            <form onsubmit="signup(event)">
                <div class="form-group"><label>আপনার নাম:</label><input type="text" id="signupName" required></div>
                <div class="form-group"><label>মোবাইল নম্বর:</label><input type="tel" id="signupPhone" placeholder="01XXXXXXXXX" required></div>
                <div class="form-group"><label>পাসওয়ার্ড:</label><input type="password" id="signupPassword" required></div>
                <div class="form-group"><label>রেফার কোড (ঐচ্ছিক):</label><input type="text" id="signupReferral"></div>
                <button type="submit" class="btn-submit">✅ সাবমিট করুন</button>
            </form>
        </div>
    </div>

    <!-- Login Modal -->
    <div class="modal" id="loginModal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeModal('loginModal')">&times;</span>
            <h2>🔐 লগইন করুন</h2>
            <form onsubmit="login(event)">
                <div class="form-group"><label>মোবাইল নম্বর:</label><input type="tel" id="loginPhone" required></div>
                <div class="form-group"><label>পাসওয়ার্ড:</label><input type="password" id="loginPassword" required></div>
                <button type="submit" class="btn-submit">🔓 লগইন</button>
            </form>
        </div>
    </div>

    <!-- Daily Bonus Modal -->
    <div class="modal" id="dailyBonusModal">
        <div class="modal-content" style="text-align:center;">
            <span class="close-modal" onclick="closeModal('dailyBonusModal')">&times;</span>
            <h2>🎁 দৈনিক বোনাস</h2>
            <p style="margin: 20px 0; color:#888;">প্রতিদিনের ফ্রি রিওয়ার্ড দাবি করুন!</p>
            <button class="btn-submit" onclick="claimDailyBonus()">🎁 ৳২ বোনাস নিন</button>
        </div>
    </div>

    <div class="toast" id="toast"><span id="toastMessage"></span></div>

    <script>
        // URL থেকে অটোমেটিক রেফারেল কোড রিড করা
        window.addEventListener('load', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const refCode = urlParams.get('ref');
            if (refCode) { document.getElementById('signupReferral').value = refCode; }
        });

        const availableAds = [
            { id: 1, title: "🛍️ Daraz Shopping Premium Task", duration: 15, reward: 2.0 },
            { id: 2, title: "📱 Grameenphone Reward Ad", duration: 20, reward: 3.0 },
            { id: 3, title: "🍔 Foodpanda Offer Campaign", duration: 10, reward: 1.5 }
        ];

        let currentAdId = null; let timerInterval = null; let currentUser = null;

        function signup(event) {
            event.preventDefault();
            const name = document.getElementById('signupName').value.trim();
            const phone = document.getElementById('signupPhone').value.trim();
            const password = document.getElementById('signupPassword').value;
            const refBy = document.getElementById('signupReferral').value.trim();

            if (!/^01[3-9]\d{8}$/.test(phone)) { showToast("❌ সঠিক মোবাইল নম্বর দিন"); return; }

            database.ref('users/' + phone).once('value').then((snapshot) => {
                if (snapshot.exists()) { showToast("❌ অ্যাকাউন্ট অলরেডি আছে!"); } 
                else {
                    const myRefCode = 'REF' + Math.floor(100000 + Math.random() * 900000);
                    const userObj = {
                        name, phone, password, balance: 10, todayWatched: 0,
                        todayEarned: 0, referralCode: myRefCode, referredBy: refBy || "",
                        dailyBonusClaimed: false
                    };
                    
                    database.ref('users/' + phone).set(userObj).then(() => {
                        if (refBy) {
                            database.ref('users').orderByChild('referralCode').equalTo(refBy).once('value', (refSnapshot) => {
                                if (refSnapshot.exists()) {
                                    refSnapshot.forEach((childSnapshot) => {
                                        let rPhone = childSnapshot.key;
                                        let rData = childSnapshot.val();
                                        database.ref('users/' + rPhone).update({
                                            balance: (rData.balance || 0) + 10
                                        });
                                    });
                                }
                            });
                        }
                        localStorage.setItem('adwatch_session', phone);
                        closeModal('signupModal');
                        showToast("✅ অ্যাকাউন্ট সফল! ৳১০ বোনাস যুক্ত হয়েছে।");
                        checkSession();
                    });
                }
            });
        }

        function login(event) {
            event.preventDefault();
            const phone = document.getElementById('loginPhone').value.trim();
            const password = document.getElementById('loginPassword').value;

            database.ref('users/' + phone).once('value').then((snapshot) => {
                if (snapshot.exists() && snapshot.val().password === password) {
                    localStorage.setItem('adwatch_session', phone);
                    closeModal('loginModal');
                    showToast("✅ লগইন সফল হয়েছে!");
                    checkSession();
                } else {
                    showToast("❌ মোবাইল নম্বর বা পাসওয়ার্ড ভুল!");
                }
            });
        }

        function checkSession() {
            const loggedPhone = localStorage.getItem('adwatch_session');
            if (loggedPhone) {
                database.ref('users/' + loggedPhone).on('value', (snapshot) => {
                    if (snapshot.exists()) {
                        currentUser = snapshot.val();
                        updateUI();
                    }
                });
            } else {
                currentUser = null;
                updateUI();
            }
        }

        function logout() {
            localStorage.removeItem('adwatch_session');
            currentUser = null;
            showToast("👋 লগআউট সম্পন্ন হয়েছে");
            updateUI();
        }

        function updateUI() {
            if (currentUser) {
                document.getElementById('navButtons').style.display = 'none';
                document.getElementById('userPanel').style.display = 'flex';
                document.getElementById('displayName').textContent = currentUser.name;
                document.getElementById('displayBalance').textContent = currentUser.balance.toFixed(1);
                document.getElementById('todayWatched').textContent = currentUser.todayWatched;
                document.getElementById('todayRemaining').textContent = Math.max(0, 10 - currentUser.todayWatched);
                document.getElementById('todayEarned').textContent = currentUser.todayEarned.toFixed(1);
                document.getElementById('referralLink').value = window.location.href.split('?')[0] + "?ref=" + currentUser.referralCode;
                document.getElementById('loginRequired').style.display = 'none';
                loadAds();
            } else {
                document.getElementById('navButtons').style.display = 'flex';
                document.getElementById('userPanel').style.display = 'none';
                document.getElementById('adGrid').innerHTML = '';
                document.getElementById('loginRequired').style.display = 'block';
            }
        }

        function loadAds() {
            const adGrid = document.getElementById('adGrid'); adGrid.innerHTML = '';
            if (currentUser.todayWatched >= 10) {
                adGrid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:20px;">🎉 আজকের লিমিট শেষ! আগামীকাল আবার আসুন।</div>`;
                return;
            }
            availableAds.forEach(ad => {
                const div = document.createElement('div'); div.className = 'ad-card';
                div.innerHTML = `
                    <div class="ad-card-header"><div class="ad-icon">📺</div></div>
                    <div class="ad-card-body">
                        <h3>${ad.title}</h3><p class="ad-duration">⏱️ ${ad.duration} সেকেন্ড</p><p class="ad-reward">💰 ৳${ad.reward}</p>
                        <button class="btn-watch" onclick="startWatching(${ad.id})">Ad দেখুন</button>
                    </div>`;
                adGrid.appendChild(div);
            });
        }

        function startWatching(id) {
            currentAdId = id; const ad = availableAds.find(a => a.id === id);
            document.getElementById('timerText').textContent = ad.duration;
            document.getElementById('adProgress').style.width = '0%';
            document.getElementById('btnClaim').disabled = true;
            showModal('adWatchModal');

            window.open('https://www.effectivecpmnetwork.com/ntbaqzdb?key=7681ef7a1b425010f4571a422a7f2f75', '_blank');

            let left = ad.duration;
            timerInterval = setInterval(() => {
                left--;
                document.getElementById('timerText').textContent = left;
                document.getElementById('adProgress').style.width = ((ad.duration - left) / ad.duration * 100) + '%';
                if (left <= 0) {
                    clearInterval(timerInterval);
                    document.getElementById('btnClaim').disabled = false;
                }
            }, 1000);
        }

        function claimReward() {
            const ad = availableAds.find(a => a.id === currentAdId);
            const updatedData = {
                balance: currentUser.balance + ad.reward,
                todayEarned: currentUser.todayEarned + ad.reward,
                todayWatched: currentUser.todayWatched + 1
            };
            database.ref('users/' + currentUser.phone).update(updatedData).then(() => {
                closeModal('adWatchModal');
                showToast(`🎉 ৳${ad.reward} আপনার একাউন্টে যোগ হয়েছে!`);
            });
        }

        function claimDailyBonus() {
            if (!currentUser) return;
            if (currentUser.dailyBonusClaimed) { showToast("❌ আজকের বোনাস নেওয়া শেষ!"); closeModal('dailyBonusModal'); return; }
            database.ref('users/' + currentUser.phone).update({
                balance: currentUser.balance + 2,
                dailyBonusClaimed: true
            }).then(() => {
                closeModal('dailyBonusModal');
                showToast("🎁 ৳২ দৈনিক বোনাস যুক্ত হয়েছে!");
            });
        }

        function requestWithdraw() {
            const num = document.getElementById('withdrawNumber').value.trim();
            const amt = parseFloat(document.getElementById('withdrawAmount').value);
            if (!/^01[3-9]\d{8}$/.test(num)) { showToast("❌ সঠিক নম্বর দিন"); return; }
            if (isNaN(amt) || amt < 50) { showToast("❌ সর্বনিম্ন উইথড্র ৳৫০"); return; }
            if (amt > currentUser.balance) { showToast("❌ পর্যাপ্ত ব্যালেন্স নেই"); return; }

            database.ref('users/' + currentUser.phone).update({ balance: currentUser.balance - amt }).then(() => {
                const req = { phone: currentUser.phone, number: num, amount: amt, method: document.getElementById('withdrawMethod').value, status: "Pending" };
                database.ref('withdraws').push(req);
                showToast("✅ আবেদন সফল! ২৪ ঘণ্টার মধ্যে পেমেন্ট পাবেন।");
            });
        }

        function copyReferral() { const link = document.getElementById('referralLink'); link.select(); document.execCommand('copy'); showToast("📋 লিংক কপি হয়েছে!"); }
        function showModal(id) { document.getElementById(id).style.display = 'block'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; if(timerInterval) clearInterval(timerInterval); }
        function showToast(msg) { const t = document.getElementById('toast'); document.getElementById('toastMessage').textContent = msg; t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 3000); }
        function toggleMenu() { document.getElementById('navLinks').classList.toggle('active'); }

        document.addEventListener('DOMContentLoaded', checkSession);
    </script>
</body>
</html>
