<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Ad দেখুন, টাকা আয় করুন! বাংলাদেশের সেরা Ad দেখে আয়ের প্ল্যাটফর্ম">
    <meta name="keywords" content="ad watch, earn money, bangladesh, online income, ad দেখে আয়">
    <title>💰 AdWatch BD - Ad দেখুন, টাকা আয় করুন!</title>

    <!-- ============ AD NETWORK CODES START ============ -->

    <!-- 1. Adsterra Popunder Ad -->
    <script type="text/javascript" src="https://www.effectivecpmnetwork.com/ntbaqzdb?key=7681ef7a1b425010f4571a422a7f2f75"></script>

    <!-- 2. Adsterra Social Bar Ad (First) -->
    <script src="https://pl30110711.effectivecpmnetwork.com/28/57/36/28573663e0aeef140c29ae45a9d4bf12.js"></script>

    <!-- 4. Adsterra Social Bar Ad (Second) -->
    <script src="https://pl30110713.effectivecpmnetwork.com/d0/d3/61/d0d361ebef6d096f13c06f332c9a3829.js"></script>

    <!-- ============ AD NETWORK CODES END ============ -->

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        /* ===== Global Reset ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0f0f1a;
            color: #ffffff;
            overflow-x: hidden;
        }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #1a1a2e; }
        ::-webkit-scrollbar-thumb { background: #e94560; border-radius: 10px; }

        /* ===== Navbar ===== */
        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(15, 15, 26, 0.95);
            backdrop-filter: blur(10px);
            z-index: 1000;
            padding: 10px 0;
            border-bottom: 1px solid #e9456033;
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.5rem;
            font-weight: bold;
            color: #e94560;
        }

        .logo i {
            font-size: 1.8rem;
            animation: spin 3s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .nav-links {
            display: flex;
            gap: 25px;
        }

        .nav-links a {
            color: #ccc;
            text-decoration: none;
            font-size: 0.95rem;
            transition: color 0.3s;
        }

        .nav-links a:hover { color: #e94560; }

        .nav-buttons { display: flex; gap: 10px; }

        .btn-login {
            padding: 8px 20px;
            background: transparent;
            border: 2px solid #e94560;
            color: #e94560;
            border-radius: 25px;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.3s;
        }

        .btn-login:hover { background: #e94560; color: white; }

        .btn-signup {
            padding: 8px 20px;
            background: linear-gradient(135deg, #e94560, #c23152);
            border: none;
            color: white;
            border-radius: 25px;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.3s;
        }

        .btn-signup:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(233, 69, 96, 0.4);
        }

        .user-panel {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-name { color: #e94560; font-weight: bold; }

        .user-balance {
            background: linear-gradient(135deg, #00b894, #00a381);
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: bold;
            font-size: 0.9rem;
        }

        .btn-logout {
            padding: 5px 15px;
            background: #333;
            border: none;
            color: #ccc;
            border-radius: 15px;
            cursor: pointer;
            font-size: 0.8rem;
        }

        .hamburger {
            display: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: #e94560;
        }

        /* ===== Hero Section ===== */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 100px 20px;
            background: radial-gradient(ellipse at center, #1a1a3e 0%, #0f0f1a 70%);
        }

        .hero-content { max-width: 800px; }

        .hero h1 {
            font-size: 2.8rem;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #e94560, #f5a623);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p { font-size: 1.2rem; color: #aaa; margin-bottom: 40px; }

        .hero-stats {
            display: flex;
            justify-content: center;
            gap: 40px;
            margin-bottom: 40px;
        }

        .stat { text-align: center; }
        .stat h3 { font-size: 2rem; color: #f5a623; }
        .stat p { color: #888; font-size: 0.9rem; }

        .btn-hero {
            padding: 15px 40px;
            font-size: 1.2rem;
            background: linear-gradient(135deg, #e94560, #c23152);
            border: none;
            color: white;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(233, 69, 96, 0.7); }
            70% { box-shadow: 0 0 0 20px rgba(233, 69, 96, 0); }
            100% { box-shadow: 0 0 0 0 rgba(233, 69, 96, 0); }
        }

        .btn-hero:hover { transform: translateY(-3px); }

        /* ===== Section Title ===== */
        .section-title {
            text-align: center;
            font-size: 2rem;
            margin-bottom: 40px;
            color: #f5a623;
        }

        /* ===== How It Works ===== */
        .how-it-works {
            padding: 80px 20px;
            background: #12121f;
        }

        .steps-container {
            max-width: 1000px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 30px;
        }

        .step {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            padding: 30px;
            border-radius: 15px;
            text-align: center;
            border: 1px solid #e9456022;
            transition: all 0.3s;
        }

        .step:hover {
            transform: translateY(-10px);
            border-color: #e94560;
            box-shadow: 0 10px 30px rgba(233, 69, 96, 0.2);
        }

        .step-icon { font-size: 2.5rem; margin-bottom: 15px; }
        .step h3 { margin-bottom: 10px; color: #e94560; }
        .step p { color: #888; font-size: 0.9rem; }

        /* ===== Ad Banner Between Sections ===== */
        .ad-banner-container {
            max-width: 728px;
            margin: 20px auto;
            text-align: center;
            padding: 10px;
            background: #1a1a2e;
            border-radius: 10px;
            border: 1px dashed #e9456033;
            min-height: 90px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .ad-banner-container .ad-label {
            color: #555;
            font-size: 0.75rem;
            display: block;
            margin-bottom: 5px;
        }

        /* ===== Dashboard ===== */
        .dashboard {
            padding: 80px 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .ad-stats {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-bottom: 40px;
            flex-wrap: wrap;
        }

        .ad-stat-card {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            padding: 25px 40px;
            border-radius: 15px;
            text-align: center;
            border: 1px solid #e9456033;
            min-width: 180px;
        }

        .ad-stat-card i { font-size: 2rem; color: #e94560; margin-bottom: 10px; }
        .ad-stat-card h3 { font-size: 1.8rem; color: #f5a623; }
        .ad-stat-card p { color: #888; font-size: 0.85rem; }

        /* ===== Ad Grid ===== */
        .ad-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

        .ad-card {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            border-radius: 15px;
            overflow: hidden;
            border: 1px solid #e9456022;
            transition: all 0.3s;
        }

        .ad-card:hover {
            transform: translateY(-5px);
            border-color: #e94560;
            box-shadow: 0 10px 25px rgba(233, 69, 96, 0.2);
        }

        .ad-card-header {
            padding: 20px;
            background: linear-gradient(135deg, #e9456022, #f5a62322);
            text-align: center;
        }

        .ad-card-header .ad-icon { font-size: 2.5rem; margin-bottom: 10px; }

        .ad-card-body { padding: 20px; }
        .ad-card-body h3 { margin-bottom: 8px; color: #fff; }
        .ad-card-body .ad-duration { color: #888; font-size: 0.9rem; margin-bottom: 5px; }
        .ad-card-body .ad-reward { color: #00b894; font-size: 1.1rem; font-weight: bold; margin-bottom: 15px; }

        .btn-watch {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #e94560, #c23152);
            border: none;
            color: white;
            border-radius: 10px;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s;
        }

        .btn-watch:hover { opacity: 0.9; transform: translateY(-2px); }
        .btn-watch:disabled { background: #333; cursor: not-allowed; transform: none; }
        .ad-completed { background: #00b894 !important; }

        .login-required {
            text-align: center;
            padding: 60px 20px;
            display: none;
        }

        .login-required i { font-size: 3rem; color: #e94560; margin-bottom: 20px; }
        .login-required h3 { margin-bottom: 10px; color: #ccc; }
        .login-required p { color: #888; margin-bottom: 20px; }

        /* ===== Ad Watching Modal ===== */
        .ad-watch-content { max-width: 600px; text-align: center; }

        .ad-watch-header { margin-bottom: 20px; }
        .ad-watch-header h2 { color: #e94560; margin-bottom: 20px; }

        .timer-circle {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 4px solid #e94560;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            font-size: 2rem;
            font-weight: bold;
            color: #f5a623;
            position: relative;
        }

        .timer-circle::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 4px solid transparent;
            border-top-color: #f5a623;
            animation: countdown 1s linear infinite;
        }

        @keyframes countdown {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .ad-display { margin: 20px 0; }
        .ad-placeholder { padding: 30px; }
        .ad-placeholder i { font-size: 3rem; color: #e94560; margin-bottom: 15px; }

        .ad-banner {
            background: #222;
            border-radius: 10px;
            padding: 20px;
            margin: 15px 0;
            min-height: 250px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .ad-content-area { text-align: center; color: #888; }

        .progress-bar {
            width: 100%;
            height: 6px;
            background: #333;
            border-radius: 10px;
            margin: 15px 0;
            overflow: hidden;
        }

        .progress {
            height: 100%;
            background: linear-gradient(90deg, #e94560, #f5a623);
            width: 0%;
            border-radius: 10px;
            transition: width 1s linear;
        }

        .ad-instruction { color: #888; margin-bottom: 15px; }

        .btn-claim {
            padding: 12px 40px;
            background: linear-gradient(135deg, #00b894, #00a381);
            border: none;
            color: white;
            border-radius: 25px;
            cursor: pointer;
            font-size: 1.1rem;
            transition: all 0.3s;
        }

        .btn-claim:disabled { background: #333; cursor: not-allowed; }
        .btn-claim:not(:disabled):hover { transform: scale(1.05); }

        /* ===== Withdraw Section ===== */
        .withdraw-section {
            padding: 80px 20px;
            background: #12121f;
        }

        .withdraw-container {
            max-width: 1000px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }

        .withdraw-info { display: flex; flex-direction: column; gap: 20px; }

        .withdraw-card {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            padding: 25px;
            border-radius: 15px;
            border: 1px solid #e9456022;
        }

        .withdraw-card h3 { color: #e94560; margin-bottom: 8px; }
        .withdraw-card p { color: #888; font-size: 0.9rem; }

        .withdraw-form {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            padding: 30px;
            border-radius: 15px;
            border: 1px solid #e9456022;
        }

        .withdraw-form h3 { color: #f5a623; margin-bottom: 20px; text-align: center; }

        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; margin-bottom: 6px; color: #ccc; font-size: 0.9rem; }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 12px 15px;
            background: #0f0f1a;
            border: 1px solid #333;
            border-radius: 10px;
            color: white;
            font-size: 1rem;
            transition: border-color 0.3s;
        }

        .form-group input:focus,
        .form-group select:focus { outline: none; border-color: #e94560; }

        .btn-withdraw {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #f5a623, #e8961e);
            border: none;
            color: white;
            border-radius: 10px;
            cursor: pointer;
            font-size: 1rem;
            font-weight: bold;
            transition: all 0.3s;
        }

        .btn-withdraw:hover { transform: translateY(-2px); }

        .btn-submit {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #e94560, #c23152);
            border: none;
            color: white;
            border-radius: 10px;
            cursor: pointer;
            font-size: 1rem;
            font-weight: bold;
            transition: all 0.3s;
            margin-top: 5px;
        }

        .btn-submit:hover { transform: translateY(-2px); }

        /* ===== Referral Section ===== */
        .referral-section {
            padding: 80px 20px;
            text-align: center;
            max-width: 800px;
            margin: 0 auto;
        }

        .referral-content p { color: #aaa; margin-bottom: 20px; }

        .referral-bonus {
            background: linear-gradient(135deg, #f5a623, #e8961e);
            padding: 25px;
            border-radius: 15px;
            margin-bottom: 25px;
        }

        .referral-bonus h3 { font-size: 1.5rem; color: #000; }
        .referral-bonus p { color: #222; margin-bottom: 0; }

        .referral-link-box {
            display: flex;
            gap: 10px;
            max-width: 500px;
            margin: 0 auto;
        }

        .referral-link-box input {
            flex: 1;
            padding: 12px;
            background: #1a1a2e;
            border: 1px solid #333;
            border-radius: 10px;
            color: #ccc;
            font-size: 0.9rem;
        }

        .referral-link-box button {
            padding: 12px 20px;
            background: #e94560;
            border: none;
            color: white;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
            white-space: nowrap;
        }

        .referral-link-box button:hover { background: #c23152; }

        /* ===== Leaderboard ===== */
        .leaderboard-section {
            padding: 80px 20px;
            background: #12121f;
        }

        .leaderboard-container {
            max-width: 600px;
            margin: 0 auto;
        }

        .leaderboard-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px 20px;
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            border-radius: 12px;
            margin-bottom: 10px;
            border: 1px solid #e9456022;
            transition: all 0.3s;
        }

        .leaderboard-item:hover {
            border-color: #e94560;
            transform: translateX(5px);
        }

        .leaderboard-rank {
            font-size: 1.5rem;
            font-weight: bold;
            min-width: 40px;
            text-align: center;
        }

        .leaderboard-rank.gold { color: #FFD700; }
        .leaderboard-rank.silver { color: #C0C0C0; }
        .leaderboard-rank.bronze { color: #CD7F32; }

        .leaderboard-info { flex: 1; }
        .leaderboard-info h4 { color: #fff; }
        .leaderboard-info p { color: #888; font-size: 0.85rem; }

        .leaderboard-amount {
            color: #00b894;
            font-weight: bold;
            font-size: 1.1rem;
        }

        /* ===== Modal ===== */
        .modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(5px);
            animation: fadeIn 0.3s;
        }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        .modal-content {
            background: #1a1a2e;
            margin: 5% auto;
            padding: 30px;
            border-radius: 20px;
            width: 90%;
            max-width: 450px;
            border: 1px solid #e9456033;
            position: relative;
            animation: slideDown 0.3s;
        }

        @keyframes slideDown {
            from { transform: translateY(-50px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .close-modal {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 1.8rem;
            color: #888;
            cursor: pointer;
            transition: color 0.3s;
        }

        .close-modal:hover { color: #e94560; }

        .modal-content h2 { text-align: center; color: #e94560; margin-bottom: 25px; }

        .modal-switch { text-align: center; margin-top: 15px; color: #888; }
        .modal-switch a { color: #e94560; text-decoration: none; }

        /* ===== Toast ===== */
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            color: white;
            padding: 15px 30px;
            border-radius: 10px;
            border: 1px solid #e94560;
            z-index: 3000;
            transition: transform 0.4s;
            font-size: 0.95rem;
        }

        .toast.show { transform: translateX(-50%) translateY(0); }

        /* ===== Footer ===== */
        .footer {
            background: #0a0a15;
            padding: 40px 20px 20px;
            border-top: 1px solid #e9456022;
        }

        .footer-content {
            max-width: 1000px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
            margin-bottom: 30px;
        }

        .footer-section h3 { color: #e94560; margin-bottom: 10px; }

        .footer-section p,
        .footer-section a {
            color: #888;
            font-size: 0.9rem;
            text-decoration: none;
            display: block;
            margin-bottom: 5px;
        }

        .footer-section a:hover { color: #e94560; }

        .footer-bottom {
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid #222;
            color: #555;
            font-size: 0.85rem;
        }

        /* ===== Notification Bell ===== */
        .notification-bell {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #e94560, #c23152);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.5rem;
            z-index: 999;
            animation: bellRing 2s infinite;
            box-shadow: 0 5px 20px rgba(233, 69, 96, 0.5);
        }

        @keyframes bellRing {
            0% { transform: rotate(0); }
            10% { transform: rotate(15deg); }
            20% { transform: rotate(-15deg); }
            30% { transform: rotate(0); }
            100% { transform: rotate(0); }
        }

        /* ===== Responsive ===== */
        @media (max-width: 768px) {
            .nav-links {
                display: none;
                position: absolute;
                top: 60px;
                left: 0;
                width: 100%;
                background: #1a1a2e;
                flex-direction: column;
                padding: 20px;
                gap: 15px;
                border-bottom: 2px solid #e94560;
            }

            .nav-links.active { display: flex; }
            .nav-buttons { display: none; }
            .user-panel { display: none !important; }
            .hamburger { display: block; }
            .hero h1 { font-size: 1.8rem; }
            .hero-stats { flex-direction: column; gap: 15px; }
            .withdraw-container { grid-template-columns: 1fr; }
            .ad-stats { flex-direction: column; align-items: center; }
            .modal-content { margin: 10% auto; width: 95%; }
            .referral-link-box { flex-direction: column; }
            .ad-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- Notification Bell -->
    <div class="notification-bell" onclick="showModal('dailyBonusModal')">
        🔔
    </div>

    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">
                <i class="fas fa-coins"></i>
                <span>AdWatch BD</span>
            </div>
            <div class="nav-links" id="navLinks">
                <a href="#home">🏠 হোম</a>
                <a href="#how-it-works">📋 কিভাবে কাজ করে</a>
                <a href="#earnings">💰 আয়</a>
                <a href="#leaderboard">🏆 লিডারবোর্ড</a>
                <a href="#withdraw">💳 উত্তোলন</a>
            </div>
