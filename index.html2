    <!-- Daily Bonus Modal -->
    <div class="modal" id="dailyBonusModal">
        <div class="modal-content" style="text-align:center;">
            <span class="close-modal" onclick="closeModal('dailyBonusModal')">&times;</span>
            <h2>🎁 দৈনিক বোনাস!</h2>
            <div style="font-size:4rem; margin:20px 0;">🎉</div>
            <h3 style="color:#f5a623; margin-bottom:15px;">প্রতিদিন লগইন করে ফ্রি বোনাস নিন!</h3>
            <p style="color:#888; margin-bottom:20px;">প্রতিদিন ৳২ বোনাস পাবেন</p>
            <button class="btn-submit" onclick="claimDailyBonus()" id="dailyBonusBtn">
                🎁 বোনাস নিন
            </button>
        </div>
    </div>

    <!-- Toast -->
    <div class="toast" id="toast">
        <span id="toastMessage"></span>
    </div>

    <script>
        // Data Management
        function generateId() { return 'user_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9); }
        function generateReferralCode() { return 'REF' + Math.random().toString(36).substr(2, 6).toUpperCase(); }
        function getUsers() { return JSON.parse(localStorage.getItem('adwatch_users') || '[]'); }
        function saveUsers(users) { localStorage.setItem('adwatch_users', JSON.stringify(users)); }
        
        function getCurrentUser() {
            const userId = localStorage.getItem('adwatch_current_user');
            if (!userId) return null;
            return getUsers().find(u => u.id === userId) || null;
        }

        function updateCurrentUser(userData) {
            const users = getUsers();
            const index = users.findIndex(u => u.id === userData.id);
            if (index !== -1) { users[index] = userData; saveUsers(users); }
        }

        // Ads Data Base
        const availableAds = [
            { id: 1, title: "🛍️ Daraz Shopping Super Sale", duration: 15, reward: 2.0, icon: "🛍️", category: "Shopping" },
            { id: 2, title: "📱 Grameenphone Special Data Offer", duration: 20, reward: 3.0, icon: "📱", category: "Telecom" },
            { id: 3, title: "🍔 Foodpanda Exclusive Voucher", duration: 10, reward: 1.5, icon: "🍔", category: "Food" },
            { id: 4, title: "🎮 Mobile Legends New Update", duration: 25, reward: 4.0, icon: "🎮", category: "Gaming" },
            { id: 5, title: "👗 Yellow Winter Fashion Trend", duration: 15, reward: 2.0, icon: "👗", category: "Fashion" }
        ];

        // Auth Operations
        function signup(event) {
            event.preventDefault();
            const name = document.getElementById('signupName').value.trim();
            const phone = document.getElementById('signupPhone').value.trim();
            const password = document.getElementById('signupPassword').value;
            const referralCode = document.getElementById('signupReferral').value.trim();

            if (!/^01[3-9]\d{8}$/.test(phone)) { showToast("❌ সঠিক মোবাইল নম্বর দিন"); return; }
            if (password.length < 6) { showToast("❌ পাসওয়ার্ড কমপক্ষে ৬ অক্ষর দিন"); return; }

            const users = getUsers();
            if (users.find(u => u.phone === phone)) { showToast("❌ অ্যাকাউন্ট অলরেডি আছে!"); return; }

            const newUser = {
                id: generateId(), name, phone, password, balance: 10, totalEarned: 10,
                todayWatched: 0, todayEarned: 0, lastActiveDate: new Date().toDateString(),
                watchedAds: [], referralCode: generateReferralCode(), referredBy: referralCode || null,
                referralCount: 0, withdrawalHistory: [], streakDays: 1, dailyBonusClaimed: false
            };

            if (referralCode) {
                const referrer = users.find(u => u.referralCode === referralCode);
                if (referrer) { referrer.balance += 10; referrer.totalEarned += 10; referrer.referralCount += 1; }
            }

            users.push(newUser); saveUsers(users);
            localStorage.setItem('adwatch_current_user', newUser.id);
            closeModal('signupModal');
            showToast("✅ অ্যাকাউন্ট তৈরি সফল! ৳১০ ফ্রি বোনাস!");
            updateUI();
        }

        function login(event) {
            event.preventDefault();
            const phone = document.getElementById('loginPhone').value.trim();
            const password = document.getElementById('loginPassword').value;

            const user = getUsers().find(u => u.phone === phone && u.password === password);
            if (!user) { showToast("❌ নম্বর বা পাসওয়ার্ড ভুল!"); return; }

            if (user.lastActiveDate !== new Date().toDateString()) {
                user.todayWatched = 0; user.todayEarned = 0; user.watchedAds = []; user.dailyBonusClaimed = false;
                user.streakDays = (user.lastActiveDate === new Date(Date.now() - 86400000).toDateString()) ? (user.streakDays + 1) : 1;
                user.lastActiveDate = new Date().toDateString();
                updateCurrentUser(user);
            }

            localStorage.setItem('adwatch_current_user', user.id);
            closeModal('loginModal');
            showToast(`✅ স্বাগতম ${user.name}!`);
            updateUI();
        }

        function logout() {
            localStorage.removeItem('adwatch_current_user');
            showToast("👋 লগআউট সম্পন্ন হয়েছে");
            updateUI();
        }

        // Interface Controllers
        function updateUI() {
            const user = getCurrentUser();
            if (user) {
                document.getElementById('navButtons').style.display = 'none';
                document.getElementById('userPanel').style.display = 'flex';
                document.getElementById('displayName').textContent = `👤 ${user.name}`;
                document.getElementById('displayBalance').textContent = user.balance.toFixed(1);
                document.getElementById('todayWatched').textContent = user.todayWatched;
                document.getElementById('todayRemaining').textContent = Math.max(0, 10 - user.todayWatched);
                document.getElementById('todayEarned').textContent = user.todayEarned.toFixed(1);
                document.getElementById('streakDays').textContent = user.streakDays;
                document.getElementById('referralLink').value = window.location.href.split('?')[0] + "?ref=" + user.referralCode;
                document.getElementById('loginRequired').style.display = 'none';
                loadAds(user);
                if (!user.dailyBonusClaimed && user.todayWatched === 0) setTimeout(() => showModal('dailyBonusModal'), 1500);
            } else {
                document.getElementById('navButtons').style.display = 'flex';
                document.getElementById('userPanel').style.display = 'none';
                document.getElementById('adGrid').innerHTML = '';
                document.getElementById('loginRequired').style.display = 'block';
            }
        }

        function loadAds(user) {
            const adGrid = document.getElementById('adGrid'); adGrid.innerHTML = '';
            if (user.todayWatched >= 10) {
                adGrid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:30px;">🎉 আজকের সব Ad শেষ! কাল আবার আসুন।</div>`;
                return;
            }
            availableAds.forEach(ad => {
                const card = document.createElement('div'); card.className = 'ad-card';
                card.innerHTML = `
                    <div class="ad-card-header"><div class="ad-icon">${ad.icon}</div></div>
                    <div class="ad-card-body">
                        <h3>${ad.title}</h3>
                        <p class="ad-duration">⏱️ ${ad.duration} সেকেন্ড</p>
                        <p class="ad-reward">💰 ৳${ad.reward}</p>
                        <button class="btn-watch" onclick="startWatching(${ad.id})">📺 Ad দেখুন</button>
                    </div>`;
                adGrid.appendChild(card);
            });
        }

        // Ad Player Trigger
        let currentAdId = null; let timerInterval = null;
        function startWatching(adId) {
            const user = getCurrentUser();
            if (user.todayWatched >= 10) { showToast("❌ দৈনিক লিমিট শেষ!"); return; }
            const ad = availableAds.find(a => a.id === adId);
            currentAdId = adId;

            document.getElementById('adTitle').textContent = ad.title;
            document.getElementById('timerText').textContent = ad.duration;
            document.getElementById('adProgress').style.width = '0%';
            document.getElementById('btnClaim').disabled = true;
            showModal('adWatchModal');

            // Trigger Popunder Ad link simultaneously to reward publisher
            window.open('https://www.effectivecpmnetwork.com/ntbaqzdb?key=7681ef7a1b425010f4571a422a7f2f75', '_blank');

            let timeLeft = ad.duration;
            timerInterval = setInterval(() => {
                timeLeft--;
                document.getElementById('timerText').textContent = timeLeft;
                document.getElementById('adProgress').style.width = ((ad.duration - timeLeft) / ad.duration * 100) + '%';
                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    document.getElementById('timerText').textContent = '✅';
                    document.getElementById('btnClaim').disabled = false;
                    document.getElementById('adInstruction').textContent = "🎉 বোনাস প্রস্তুত! নিচে ক্লিক করুন।";
                }
            }, 1000);
        }

        function claimReward() {
            const user = getCurrentUser(); const ad = availableAds.find(a => a.id === currentAdId);
            user.balance += ad.reward; user.totalEarned += ad.reward; user.todayEarned += ad.reward; user.todayWatched += 1;
            updateCurrentUser(user); closeModal('adWatchModal');
            showToast(`🎉 ৳${ad.reward} আপনার একাউন্টে যোগ হয়েছে!`);
            updateUI();
        }

        function claimDailyBonus() {
            const user = getCurrentUser();
            if (user.dailyBonusClaimed) return;
            user.balance += 2; user.totalEarned += 2; user.dailyBonusClaimed = true;
            updateCurrentUser(user); closeModal('dailyBonusModal');
            showToast("🎁 ৳২ দৈনিক বোনাস যুক্ত হয়েছে!");
            updateUI();
        }

        function requestWithdraw() {
            const user = getCurrentUser();
            const method = document.getElementById('withdrawMethod').value;
            const number = document.getElementById('withdrawNumber').value.trim();
            const amount = parseFloat(document.getElementById('withdrawAmount').value);
            if (!/^01[3-9]\d{8}$/.test(number)) { showToast("❌ সঠিক নম্বর দিন"); return; }
            if (isNaN(amount) || amount < 50) { showToast("❌ সর্বনিম্ন উইথড্র ৳৫০"); return; }
            if (amount > user.balance) { showToast("❌ পর্যাপ্ত ব্যালেন্স নেই"); return; }

            user.balance -= amount;
            user.withdrawalHistory.push({ method, number, amount, date: new Date().toLocaleDateString(), status: 'Pending' });
            updateCurrentUser(user); showToast("✅ আবেদন সফল! ২৪ ঘন্টায় পেমেন্ট পাবেন।");
            updateUI();
        }

        function copyReferral() {
            const link = document.getElementById('referralLink'); link.select();
            document.execCommand('copy'); showToast("📋 লিংক কপি হয়েছে!");
        }

        function showModal(id) { document.getElementById(id).style.display = 'block'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; if(timerInterval) clearInterval(timerInterval); }
        function showToast(msg) { const t = document.getElementById('toast'); document.getElementById('toastMessage').textContent = msg; t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 3000); }
        function toggleMenu() { document.getElementById('navLinks').classList.toggle('active'); }

        document.addEventListener('DOMContentLoaded', updateUI);
    </script>
</body>
</html>
